# Server
PORT=3001
CORS_ORIGIN=http://localhost:4200

# MySQL
DB_HOST=db
DB_USER=osp_user
DB_PASSWORD=change_me
DB_NAME=osp_db
DB_PORT=3306

# DigitalOcean Managed MySQL typically requires TLS.
# Options: disable | prefer | require
DB_SSL_MODE=disable
# Provide ONE of the following when using TLS:
# - DB_SSL_CA_PATH=/absolute/path/to/ca-certificate.crt
# - DB_SSL_CA_BASE64=... (base64-encoded CA cert contents)
DB_SSL_CA_PATH=
DB_SSL_CA_BASE64=
