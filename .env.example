# Used by docker-compose.yml
DB_NAME=osp_db
# Note: db/init.sql seeds `osp_db`. If you change DB_NAME, update db/init.sql too.
DB_USER=osp_user
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me_root

API_PORT=3001
CORS_ORIGIN=http://localhost:4200

# Node API (JWT)
# Use long random strings in production.
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
# Optional (seconds)
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Legacy PHP app
PHP_PORT=8081
GOOGLE_MAPS_API_KEY=

# Stripe (Test mode)
# Use your *test* keys from Stripe Dashboard (Developers → API keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_CURRENCY=usd
